{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListPortalBucket",
            "Effect": "Allow",
            "Action": "s3:ListBucket",
            "Resource": "arn:aws:s3:::student-registration-portal"
        },
        {
            "Sid": "ReadPortalZip",
            "Effect": "Allow",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::student-registration-portal/student-registration-portal.zip"
        }
    ]
}